{
  "name": "mtc-essay-style",
  "version": "1.0.0",
  "description": "Style checker and word counter for Word (.docx) documents",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mtc-essay-style": "./dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ --ext .ts,.tsx",
    "start": "tsx src/cli/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "tsc -w"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fast-xml-parser": "^5.9.3",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.0.0",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
